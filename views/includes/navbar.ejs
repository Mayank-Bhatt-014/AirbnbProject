<style>
    .search-btn{
      background-color: #fe424d;
      color: #fff;
      border-radius: 25px;
      padding: 0 1rem 0 1rem; /* clockwise*/
    }

    .search-btn:hover{
      background-color: #fe424d;
      color: #fff;
      border: 1px solid black;

    }

    .search-btn i{
      display: inline;
      margin-right: 0.5rem;
    }

    .search-inp{
      border-radius: 25px;
      padding: 0.5rem 3rem 0.5rem 3rem;
      font-size: 0.9rem;
    }

    .nav-link{
      border-radius: 25px;
    }
    .nav-link:hover{
      background-color: #ececec;
      border-radius: 25px;
    }

    /* AI Search button */
    .ai-search-btn{
      display:inline-block;
      background-color:#0069ff;
      color:#fff !important;
      border-radius:25px;
      padding:0.45rem 1rem;
      font-weight:600;
      text-decoration:none;
      transition: background-color 0.1s ease-in-out, transform 0.1s ease-in-out;
      margin-left:0.5rem;
    }
    .ai-search-btn:hover{
      background-color:#4da6ff;
      color:#fff !important;
      transform:translateY(-1px);
    }



</style>




<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings"><i class="fa-brands fa-airbnb"></i></a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-link" aria-current="page" href="/listings">Explore</a>
      </div>
      <div class="navbar-nav ms-auto">
        <form class="d-flex" role="search" method="get" action="/listings">
          <input class="form-control me-2 search-inp" name="search" type="search" placeholder="Search Country" aria-label="Search"/>
          <button class="btn search-btn" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search</button>
        </form>
      </div>

      <!-- AI Search button placed between search and right-side links -->
      <div class="navbar-nav align-items-center">
        <a class="nav-link ai-search-btn" href="/concierge">AI Search</a>
      </div>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/listings/new">Become a host</a>
          <% if (typeof currUser === 'undefined' || !currUser) { %>
            <a class="nav-link" aria-current="page" href="/signup"><b>Sign up</b></a>
            <a class="nav-link" href="/login"><b>Log in</b></a>
          <% } %>
           <% if (typeof currUser !== 'undefined' && currUser) { %>
          <a class="nav-link" href="/logout">Log out</a>
          <% } %>
        
      </div>
    </div>
  </div>
</nav>