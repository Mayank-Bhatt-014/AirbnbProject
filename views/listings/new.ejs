<% layout("/layouts/boilerplate") %>
    <div class="row">
        <div class="col-8 offset-2">
            <h3> Create a new listing</h3>
            <form method="post" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
            
                <div class="mb-3">
                    <lable for="title" class="form-label">Title</lable>
                    <input name="listing[title]" type="text" class="form-control" placeholder=" Enter Title" required>
                    <div class="invalid-feedback"> Title is required. </div>
                </div>
                <div class="mb-3">
                    <lable for="description" class="form-label">Description</lable>
                    <textarea name="listing[description]" class="form-control" required></textarea>
                    <div class="invalid-feedback"> Please enter Description </div>
                </div>
            
                <br>
                <!-- <div class="mb-3">
                    <lable for="image" class="form-label">Image link</lable>
                    <input name="listing[image][url]" placeholder="Enter image URL/Link" value="https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTV8fGhvdGVsc3xlbnwwfHwwfHx8MA%3D%3D&auto=format&fit=crop&w=800&q=60" type="text" class="form-control"> 
                </div class="mb-3">
                <br> -->

                <div class="mb-3">
                    <lable for="image" class="form-label">Upload Listing Image</lable>
                    <input id="imageInput" name="listing[image][url]" type="file" class="form-control" accept="image/*"  required>
                    <div class="invalid-feedback"> Upload the Photo(must be .png , .jpg , .jpeg) </div>
                </div class="mb-3">
                <br>


                <!-- Image preview area -->
                <div class="text-center my-3" style="display:none;" id="previewContainer">
                    <img id="previewImage" style="max-width:100%; max-height:400px;"/>
                    <br>
                    <button type="button" id="cropBtn" class="btn btn-primary mt-3">Crop & Use</button>
                </div>

                <div class="container my-4" id="previewContainer" style="display:none;">
                    <div class="row justify-content-center">
                        <div class="col-6">
                        <div class="card shadow-sm">
                            <div class="card-body text-center">
                            <div class="crop-container" style="width:100%; aspect-ratio: 4/3; overflow:hidden;">
                                <img id="previewImage" style="width:100%; display:block;"/>
                            </div>
                            <button type="button" id="cropBtn" class="btn btn-primary mt-3">Crop & Use</button>
                            </div>
                        </div>
                        </div>
                    </div>
                </div>
                <br>
                
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <lable for="price" class="form-label">Price</lable>
                        <input name="listing[price]" placeholder="Enter price" type="number" class="form-control"  required>
                        <div class="invalid-feedback"> Please enter a valid price </div>
                    </div>  
                
                    <br>
                    <div class="mb-3 col-md-8">
                        <lable for="country"class="form-label">Country</lable>
                        <input name="listing[country]" placeholder="Enter Country" type="text" class="form-control" required>
                        <div class="invalid-feedback"> Please enter the country</div>
                    
                    </div>
                </div>
                <br>
                <div class="mb-3">
                    <lable for="location"class="form-label" >location</lable>
                    <input name="listing[location]" placeholder="Enter the location" type="text" class="form-control" required>
                    <div class="invalid-feedback"> Please enter the location </div>
                </div>
        
            
                <br>
                <button class="btn btn-dark"> Add</button>
            </form>

        </div>
    </div>

<script src="/js/cropper.js"></script>
