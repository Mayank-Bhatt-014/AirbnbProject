<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <div class="col-6 offset-3">
        <h1 class="col-6 offset-3"> Sign up on Airbnb </h1>
        <form action="/signup" method="POST" novalidate class="needs-validation">
            <div class="mb-3">
                <lable for="username" class="form-label">UserName</lable>
                <input name="username" type="text" class="form-control" placeholder=" Enter Username" required>
                <div class="invalid-feedback"> Username is required. </div>
            </div>
            <div class="mb-3">
                <lable for="email" class="form-label">Email</lable>
                <input name="email" type="text" class="form-control" placeholder=" Enter Email" required>
                <div class="invalid-feedback"> Email is required. </div>
            </div>
            <div class="mb-3">
                <lable for="password" class="form-label">Password</lable>
                <input name="password" type="password" class="form-control" placeholder=" Enter Password" required>
                <div class="invalid-feedback"> Password is required. </div>
            </div>
            <p>Already have an account? <a href="/login">Login to Airbnb!</a></p>
            <button class="btn btn-success"> SignUp</button>
        </form>

    </div>
</div>